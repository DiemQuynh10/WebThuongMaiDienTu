@model ShopMVC.Models.ThuongHieu
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
@{
    ViewData["Title"] = "Sửa thương hiệu";
}

<div class="container-xxl py-4">
    <!-- Header -->
    <div class="d-flex align-items-center justify-content-between mb-3">
        <h3 class="mb-0">@ViewData["Title"]</h3>
        <div class="d-flex gap-2">
            <a asp-action="Index" class="btn btn-sm btn-outline-secondary">
                <i class="bi bi-arrow-left"></i> Quay lại
            </a>
        </div>
    </div>

    <!-- Card form -->
    <form asp-action="Edit" method="post" novalidate>
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="Id" />

        <div class="card border-0 shadow-sm">
            <div class="card-body">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-2"></div>

                <div class="row g-3">
                    <div class="col-12">
                        <label class="form-label">Tên</label>
                        <input asp-for="Ten" class="form-control" placeholder="VD: Apple, Samsung..." />
                        <span asp-validation-for="Ten" class="text-danger"></span>
                    </div>

                    <div class="col-12 col-md-8">
                        <label class="form-label">Slug</label>
                        <div class="input-group">
                            <span class="input-group-text text-muted">/brand/</span>
                            <input asp-for="Slug" class="form-control" id="slugInput" placeholder="vd: apple" />
                            <button class="btn btn-outline-secondary" type="button" id="btnAutoSlug" title="Tạo slug từ tên">
                                Tạo từ tên
                            </button>
                        </div>
                        <div class="form-text">Slug dùng cho URL. Bạn có thể để trống, hệ thống sẽ tự sinh.</div>
                        <span asp-validation-for="Slug" class="text-danger"></span>
                    </div>

                    <div class="col-12 col-md-4 d-flex align-items-center">
                        <div class="form-check mt-4">
                            <input asp-for="HienThi" class="form-check-input" id="hienthiChk" />
                            <label class="form-check-label" for="HienThi">Hiển thị</label>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Footer actions -->
            <div class="card-footer bg-white d-flex justify-content-end gap-2">
                <a asp-action="Index" class="btn btn-outline-secondary">Quay lại</a>
                <button class="btn btn-primary">
                    <i class="bi bi-check2-circle me-1"></i> Cập nhật
                </button>
            </div>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        // tạo slug VN-friendly từ tên
        function slugify(str) {
            if (!str) return "";
            return str
                .toLowerCase()
                .normalize('NFD').replace(/[\u0300-\u036f]/g, '') // bỏ dấu
                .replace(/đ/g, 'd')
                .replace(/[^a-z0-9]+/g, '-')   // non-alnum => -
                .replace(/^-+|-+$/g, '')       // trim -
                .substring(0, 80);
        }

        // nút "Tạo từ tên"
        document.getElementById('btnAutoSlug')?.addEventListener('click', function () {
            const name = document.getElementById('Ten')?.value || '';
            const slug = slugify(name);
            const input = document.getElementById('slugInput');
            if (input) input.value = slug;
        });

        // nếu slug đang trống, tự gợi ý khi gõ tên (không ép buộc)
        const tenInput = document.getElementById('Ten');
        const slugInput = document.getElementById('slugInput');
        tenInput?.addEventListener('input', () => {
            if (slugInput && !slugInput.value) {
                slugInput.placeholder = slugify(tenInput.value);
            }
        });
    </script>
}
