@model ShopMVC.Models.ViewModels.VoucherEditVM
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
@{
    ViewData["Title"] = "Tạo voucher";
}

<h2 class="mb-3">Tạo voucher</h2>

<form asp-area="Admin"
      asp-controller="Voucher"
      asp-action="Create"
      method="post"
      class="row g-3">
    @Html.AntiForgeryToken()
    <div asp-validation-summary="All" class="text-danger small"></div>

    <!-- ====== THÔNG TIN VOUCHER CƠ BẢN ====== -->
    <div class="col-md-4">
        <label class="form-label">Mã voucher</label>
        <input asp-for="Voucher.Code" class="form-control" />
        <span asp-validation-for="Voucher.Code" class="text-danger"></span>
    </div>

    <!-- Nếu m có trường Tên/Title thì mở comment này -->
    <div class="col-md-8">
        <label class="form-label">Tên/ghi chú voucher</label>
        <input asp-for="Voucher.Ten" class="form-control" />
        <span asp-validation-for="Voucher.Ten" class="text-danger"></span>
    </div> 
    <!-- Giảm trực tiếp hoặc % giảm — chỉnh lại theo đúng tên field trong Voucher.cs của m -->
    <div class="col-md-4">
        <label class="form-label">% giảm</label>
        <input asp-for="Voucher.PhanTramGiam" type="number" step="0.01" min="0" max="100" class="form-control" />
        <span asp-validation-for="Voucher.PhanTramGiam" class="text-danger"></span>
    </div>

    <div class="col-md-4">
        <label class="form-label">Giảm trực tiếp (đ)</label>
        <input asp-for="Voucher.GiamTrucTiep" type="number" step="1000" min="0" class="form-control" />
        <span asp-validation-for="Voucher.GiamTrucTiep" class="text-danger"></span>
    </div>

    <div class="col-md-4">
        <label class="form-label">Giảm tối đa (đ)</label>
        <input asp-for="Voucher.GiamToiDa" type="number" step="1000" min="0" class="form-control" />
        <span asp-validation-for="Voucher.GiamToiDa" class="text-danger"></span>
    </div>

    <div class="col-md-4">
        <label class="form-label">Ngày bắt đầu</label>
        <input asp-for="Voucher.NgayBatDau" type="date" class="form-control" />
        <span asp-validation-for="Voucher.NgayBatDau" class="text-danger"></span>
    </div>

    <div class="col-md-4">
        <label class="form-label">Ngày hết hạn</label>
        <input asp-for="Voucher.NgayHetHan" type="date" class="form-control" />
        <span asp-validation-for="Voucher.NgayHetHan" class="text-danger"></span>
    </div>


    <div class="col-md-4">
        <label class="form-label">Lượt dùng tối đa</label>
        <input asp-for="Voucher.SoLanSuDungToiDa" type="number" min="0" class="form-control" />
        <span asp-validation-for="Voucher.SoLanSuDungToiDa" class="text-danger"></span>
    </div>

    <div class="col-md-4 d-flex align-items-end">
        <div class="form-check">
            <input class="form-check-input" asp-for="Voucher.IsActive" />
            <label class="form-check-label" for="Voucher_IsActive">Kích hoạt</label>
        </div>
    </div>

    <hr class="my-3" />

    <!-- ====== GIỚI HẠN THEO THƯƠNG HIỆU ====== -->
    <div class="col-12">
        <label class="form-label fw-bold">Giới hạn theo Thương hiệu</label>
        <div class="row row-cols-2 row-cols-md-3 row-cols-lg-4 g-2">
            @foreach (var th in Model.AllThuongHieus)
            {
                <div class="col">
                    <label class="form-check">
                        <input class="form-check-input" type="checkbox"
                               name="SelectedThuongHieuIds" value="@th.Id" />
                        <span class="form-check-label">@th.Ten</span>
                    </label>
                </div>
            }
        </div>
        <div class="form-text">Không chọn gì = áp dụng cho tất cả thương hiệu.</div>
    </div>

    <!-- ====== GIỚI HẠN THEO DANH MỤC ====== -->
    <div class="col-12">
        <label class="form-label fw-bold">Giới hạn theo Danh mục</label>
        <div class="row row-cols-2 row-cols-md-3 row-cols-lg-4 g-2">
            @foreach (var dm in Model.AllDanhMucs)
            {
                <div class="col">
                    <label class="form-check">
                        <input class="form-check-input" type="checkbox"
                               name="SelectedDanhMucIds" value="@dm.Id" />
                        <span class="form-check-label">@dm.Ten</span>
                    </label>
                </div>
            }
        </div>
        <div class="form-text">Không chọn gì = áp dụng cho tất cả danh mục.</div>
    </div>

    <div class="col-12 d-flex gap-2 mt-2">
        <button type="submit" class="btn btn-primary">Lưu</button>
        <a asp-area="Admin" asp-controller="Voucher" asp-action="Index" class="btn btn-outline-secondary">Hủy</a>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
