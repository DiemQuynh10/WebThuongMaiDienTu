@model ShopMVC.Models.DonHang
@{
    ViewData["Title"] = "Đơn #" + Model.MaDon;
}
<div class="container py-4">
    <h2>Đơn #@Model.MaDon</h2>
    <div class="row g-4 mt-1">
        <div class="col-lg-7">
            <table class="table">
                <thead><tr><th>Sản phẩm</th><th class="text-end">SL</th><th class="text-end">Đơn giá</th><th class="text-end">Thành tiền</th></tr></thead>
                <tbody>
                    @foreach (var ct in Model.ChiTiets)
                    {
                        <tr>
                            <td>@ct.SanPham?.Ten</td>
                            <td class="text-end">@ct.SoLuong</td>
                            <td class="text-end">@ct.DonGia.ToString("n0") đ</td>
                            <td class="text-end">@ct.ThanhTien.ToString("n0") đ</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        <<div class="d-flex justify-content-between">
            <span>Tạm tính</span>
            <span>@Model.TongTruocGiam.ToString("n0") đ</span>
        </div>
        <div class="d-flex justify-content-between">
            <span>Phí vận chuyển</span>
            <span>@Model.PhiVanChuyen.ToString("n0") đ</span>
        </div>

        @if (Model.TienGiam > 0)
        {
            <div class="d-flex justify-content-between text-success">
                <span>Voucher: @Model.VoucherCode</span>
                <span>-@Model.TienGiam.ToString("n0") đ</span>
            </div>
        }

        <hr />
        <div class="d-flex justify-content-between fw-bold">
            <span>Tổng thanh toán</span>
            <span>@Model.TongThanhToan.ToString("n0") đ</span>
        </div>
        <div class="mt-2">
            <strong>Trạng thái:</strong> @Model.TrangThai
        </div>

    </div>
</div>
